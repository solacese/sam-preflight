# Runtime behavior
SAM_PREFLIGHT_NAMESPACE=solace-agent-mesh
SAM_PREFLIGHT_PROFILE=medium
# SAM_PREFLIGHT_VALUES=./values.yaml

# Optional value overrides (highest env precedence for chart values)
# SAM_PREFLIGHT_SET__sam__dnsName=sam.example.com
# SAM_PREFLIGHT_SET__samDeployment__imagePullSecret=gcr-reg-secret

# Optional external connectivity checks
# SOLACE_SEMP_BASE_URL=https://your-broker-host:943
# SOLACE_SEMP_USERNAME=admin
# SOLACE_SEMP_PASSWORD=admin-password
# SOLACE_SEMP_VERIFY_TLS=true

# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
